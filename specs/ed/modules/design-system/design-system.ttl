@prefix ujg: <https://ujg.specs.openuji.org/ed/ns/core#> .
@prefix ujggraph: <https://ujg.specs.openuji.org/ed/ns/graph#> .
@prefix ujgds: <https://ujg.specs.openuji.org/ed/ns/design-system#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

<https://ujg.specs.openuji.org/ed/ns/design-system#> a owl:Ontology ;
  rdfs:label "UJG Design System Editor's Draft Vocabulary"@en ;
  dct:description "UJG Design System ontology declaration" .

### Classes

ujgds:UIView a owl:Class ;
  rdfs:subClassOf ujg:Node .

ujgds:UITheme a owl:Class ;
  rdfs:subClassOf ujg:Node .

ujgds:UIAction a owl:Class ;
  rdfs:subClassOf ujg:Node .

### Properties

ujgds:viewRef a owl:ObjectProperty ;
  rdfs:domain ujggraph:State ;
  rdfs:range ujgds:UIView .

ujgds:themeRef a owl:ObjectProperty ;
  rdfs:domain ujgds:UIView ;
  rdfs:range ujgds:UITheme .

ujgds:actionRefs a owl:ObjectProperty ;
  rdfs:domain ujgds:UIView ;
  rdfs:range ujgds:UIAction .

ujgds:transitionRef a owl:ObjectProperty ;
  rdfs:domain ujgds:UIAction ;
  rdfs:range ujggraph:Transition .

ujgds:profile a owl:DatatypeProperty ;
  rdfs:domain ujgds:UIView ;
  rdfs:range xsd:string .

ujgds:registryItem a owl:DatatypeProperty ;
  rdfs:domain ujgds:UIView ;
  rdfs:range xsd:string .

ujgds:variant a owl:DatatypeProperty ;
  rdfs:domain ujgds:UIView ;
  rdfs:range xsd:string .

ujgds:slots a owl:DatatypeProperty ;
  rdfs:domain ujgds:UIView ;
  rdfs:range rdf:JSON .

ujgds:tokenRefs a owl:DatatypeProperty ;
  rdfs:domain ujgds:UIView ;
  rdfs:range rdf:JSON .
