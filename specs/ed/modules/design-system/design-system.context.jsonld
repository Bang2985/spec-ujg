{
  "@context": {
    "@version": 1.1,

    "ujgds": "https://ujg.specs.openuji.org/ed/ns/design-system#",
    "ds": "https://ujg.specs.openuji.org/ed/ns/design-system#",

    "UIView": "ujgds:UIView",
    "UITheme": "ujgds:UITheme",
    "UIAction": "ujgds:UIAction",

    "viewRef": {
      "@id": "ujgds:viewRef",
      "@type": "@id"
    },
    "themeRef": {
      "@id": "ujgds:themeRef",
      "@type": "@id"
    },
    "actionRefs": {
      "@id": "ujgds:actionRefs",
      "@type": "@id",
      "@container": "@set"
    },
    "transitionRef": {
      "@id": "ujgds:transitionRef",
      "@type": "@id"
    },
    "profile": "ujgds:profile",
    "registryItem": "ujgds:registryItem",
    "variant": "ujgds:variant",
    "slots": {
      "@id": "ujgds:slots",
      "@type": "@json"
    },
    "tokenRefs": {
      "@id": "ujgds:tokenRefs",
      "@type": "@json"
    }
  }
}
