@prefix ujggraph: <https://ujg.specs.openuji.org/ed/ns/graph#> .
@prefix ujgds: <https://ujg.specs.openuji.org/ed/ns/design-system#> .
@prefix ujgdsshape: <https://ujg.specs.openuji.org/ed/ns/design-system.shape#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

ujgdsshape:StateViewShape a sh:NodeShape ;
  sh:targetClass ujggraph:State ;
  sh:nodeKind sh:IRI ;

  sh:property [
    sh:path ujgds:viewRef ;
    sh:class ujgds:UIView ;
    sh:nodeKind sh:IRI ;
    sh:maxCount 1 ;
  ] .

ujgdsshape:UIViewShape a sh:NodeShape ;
  sh:targetClass ujgds:UIView ;
  sh:nodeKind sh:IRI ;

  sh:property [
    sh:path ujggraph:label ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
  ] ;

  sh:property [
    sh:path ujgds:profile ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
  ] ;

  sh:property [
    sh:path ujgds:registryItem ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;

  sh:property [
    sh:path ujgds:variant ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
  ] ;

  sh:property [
    sh:path ujgds:themeRef ;
    sh:class ujgds:UITheme ;
    sh:nodeKind sh:IRI ;
    sh:maxCount 1 ;
  ] ;

  sh:property [
    sh:path ujgds:actionRefs ;
    sh:class ujgds:UIAction ;
    sh:nodeKind sh:IRI ;
  ] ;

  sh:property [
    sh:path ujgds:slots ;
    sh:datatype rdf:JSON ;
    sh:maxCount 1 ;
  ] ;

  sh:property [
    sh:path ujgds:tokenRefs ;
    sh:datatype rdf:JSON ;
    sh:maxCount 1 ;
  ] .

ujgdsshape:UIThemeShape a sh:NodeShape ;
  sh:targetClass ujgds:UITheme ;
  sh:nodeKind sh:IRI ;

  sh:property [
    sh:path ujggraph:label ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
  ] .

ujgdsshape:UIActionShape a sh:NodeShape ;
  sh:targetClass ujgds:UIAction ;
  sh:nodeKind sh:IRI ;

  sh:property [
    sh:path ujggraph:label ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;

  sh:property [
    sh:path ujgds:transitionRef ;
    sh:class ujggraph:Transition ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .
