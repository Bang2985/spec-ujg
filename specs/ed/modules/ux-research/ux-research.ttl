@prefix ujg: <https://ujg.specs.openuji.org/ed/ns/core#> .
@prefix ujgsurface: <https://ujg.specs.openuji.org/ed/ns/surface#> .
@prefix ujguxr: <https://ujg.specs.openuji.org/ed/ns/ux-research#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .

<https://ujg.specs.openuji.org/ed/ns/ux-research#> a owl:Ontology ;
  rdfs:label "UJG UX Research Editor's Draft Vocabulary"@en ;
  dct:description "UJG UX Research ontology declaration" .

ujguxr:PainPoint a owl:Class ;
  rdfs:subClassOf ujg:Node .

ujguxr:experienceRefs a owl:ObjectProperty ;
  rdfs:domain ujguxr:PainPoint ;
  rdfs:range ujgsurface:ExperienceStep .

ujguxr:severity a owl:DatatypeProperty ;
  rdfs:domain ujguxr:PainPoint ;
  rdfs:range xsd:decimal .

ujguxr:description a owl:DatatypeProperty ;
  rdfs:domain ujguxr:PainPoint ;
  rdfs:range xsd:string .
