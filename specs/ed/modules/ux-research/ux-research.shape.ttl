@prefix ujguxr: <https://ujg.specs.openuji.org/ed/ns/ux-research#> .
@prefix ujgsurface: <https://ujg.specs.openuji.org/ed/ns/surface#> .
@prefix ujguxrshape: <https://ujg.specs.openuji.org/ed/ns/ux-research.shape#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ujguxrshape:PainPointShape a sh:NodeShape ;
  sh:targetClass ujguxr:PainPoint ;
  sh:nodeKind sh:IRI ;

  sh:property [
    sh:path ujguxr:experienceRefs ;
    sh:class ujgsurface:ExperienceStep ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
  ] ;

  sh:property [
    sh:path ujguxr:severity ;
    sh:datatype xsd:decimal ;
    sh:minInclusive 0 ;
    sh:maxInclusive 1 ;
    sh:maxCount 1 ;
  ] ;

  sh:property [
    sh:path ujguxr:description ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
  ] .
