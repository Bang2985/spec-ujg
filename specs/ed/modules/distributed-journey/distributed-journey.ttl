@prefix ujgartifact: <https://ujg.specs.openuji.org/ed/ns/artifact#> .
@prefix ujgdist: <https://ujg.specs.openuji.org/ed/ns/distributed-journey#> .
@prefix ujgsurface: <https://ujg.specs.openuji.org/ed/ns/surface#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dct: <http://purl.org/dc/terms/> .

<https://ujg.specs.openuji.org/ed/ns/distributed-journey#> a owl:Ontology ;
  rdfs:label "UJG Distributed Journey Editor's Draft Vocabulary"@en ;
  dct:description "UJG Distributed Journey ontology declaration" .

### Classes

ujgdist:DistributedArtifact a owl:Class ;
  rdfs:subClassOf ujgartifact:Artifact .

### Properties

ujgdist:sourceTouchpointRef a owl:ObjectProperty ;
  rdfs:range ujgsurface:Touchpoint .

ujgdist:targetTouchpointRefs a owl:ObjectProperty ;
  rdfs:range ujgsurface:Touchpoint .
