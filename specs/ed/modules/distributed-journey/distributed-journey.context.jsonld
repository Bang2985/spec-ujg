{
  "@context": {
    "@version": 1.1,

    "ujgdist": "https://ujg.specs.openuji.org/ed/ns/distributed-journey#",
    "dist": "https://ujg.specs.openuji.org/ed/ns/distributed-journey#",

    "Authority": "ujgdist:Authority",
    "DistributedOperation": "ujgdist:DistributedOperation",
    "DistributedArtifact": "ujgdist:DistributedArtifact",

    "origin": {
      "@id": "ujgdist:origin",
      "@type": "@id"
    },
    "presentedByAuthorityRef": {
      "@id": "ujgdist:presentedByAuthorityRef",
      "@type": "@id"
    },
    "operationActionRef": {
      "@id": "ujgdist:operationActionRef",
      "@type": "@id"
    },
    "visibleSubjectRefs": {
      "@id": "ujgdist:visibleSubjectRefs",
      "@type": "@id",
      "@container": "@set"
    },
    "sourceAuthorityRef": {
      "@id": "ujgdist:sourceAuthorityRef",
      "@type": "@id"
    },
    "targetAuthorityRefs": {
      "@id": "ujgdist:targetAuthorityRefs",
      "@type": "@id",
      "@container": "@set"
    }
  }
}
